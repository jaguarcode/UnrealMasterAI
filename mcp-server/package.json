{
  "name": "unreal-master-mcp-server",
  "version": "0.4.1",
  "description": "MCP server bridging Claude AI to Unreal Engine — 183 tools across 37 domains for Blueprint, AI, materials, sequencer, and more.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "unreal-master-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "keywords": [
    "unreal-engine",
    "mcp",
    "ai",
    "claude",
    "model-context-protocol",
    "game-development",
    "blueprint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaguarcode/UnrealMasterAI.git",
    "directory": "mcp-server"
  },
  "homepage": "https://jaguarcode.github.io/UnrealMasterAI/",
  "bugs": {
    "url": "https://github.com/jaguarcode/UnrealMasterAI/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "audit:security": "npm audit --production --audit-level=moderate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  }
}
